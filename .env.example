# Copy this file to .env for local development. Never commit .env.
# All variables marked REQUIRED must be set before running in production.

# REQUIRED — MongoDB connection string
APOS_MONGODB_URI=mongodb://localhost:27017/apostrophe

# REQUIRED — Long random string used to sign sessions. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=changeme-generate-a-long-random-string

# Recommended — set to "production" in production deployments
NODE_ENV=development
